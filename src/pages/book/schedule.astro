---
import BaseLayout from '../../layouts/BaseLayout.astro';
import availability from '../../data/availability.json';

const schedule = availability.schedule;
const availableDays = Object.keys(schedule).map(Number);
const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

// Build list of next 5 available dates
const today = new Date();
today.setHours(0,0,0,0);

const dates = [];
let d = new Date(today);
while (dates.length < 5) {
  if (availableDays.includes(d.getDay())) {
    dates.push({
      iso: d.toISOString().split('T')[0],
      day: d.getDate(),
      dow: d.getDay(),
      dowName: dayNames[d.getDay()],
      month: monthNames[d.getMonth()],
    });
  }
  d.setDate(d.getDate() + 1);
}
---

<BaseLayout title="Book a Session">
  <nav>
    <a href="https://akarshanarora.com" class="nav-brand">Akarshan Arora</a>
    <div class="nav-links">
      <a href="https://akarshanarora.com">Who am I</a>
      <a href="https://www.linkedin.com/in/aroraakarshan/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://topmate.io/akarshanarora" target="_blank" rel="noopener" class="nav-cta">Book a 1:1</a>
    </div>
  </nav>

  <div class="container">
    <a href="/book/" class="back-link">&larr; Back</a>

    <p class="eyebrow">1-on-1 Session</p>
    <h1 id="service-title"></h1>
    <p id="service-meta"></p>

    <div class="field">
      <label>Pick a date</label>
      <div id="date-error" class="err">Select a date to continue.</div>
      <div class="date-pills">
        {dates.map(d => (
          <button type="button" class="date-pill" data-date={d.iso} data-dow={d.dow}>
            <span class="date-pill-dow">{d.dowName}</span>
            <span class="date-pill-num">{d.day} {d.month}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="field">
      <label>Pick a time</label>
      <div id="time-error" class="err">Select a time slot.</div>
      <div id="time-slots"></div>
    </div>

    <div class="field">
      <label>Name</label>
      <input type="text" id="name" required placeholder="Your full name" />
    </div>
    <div class="field">
      <label>Email</label>
      <input type="email" id="email" required placeholder="you@example.com" />
    </div>
    <div class="field">
      <label>Phone (optional)</label>
      <input type="tel" id="phone" placeholder="+91 99999 99999" />
    </div>

    <div class="field">
      <label>What is the call about? <span style="color:#C45D2C">*</span></label>
      <textarea id="about" required rows="3" placeholder="Topics you want to discuss, questions, goals..." style="width:100%;padding:0.7rem 0.85rem;background:var(--surface);border:1px solid var(--hairline);border-radius:8px;color:var(--ink);font-size:0.9rem;font-family:inherit;resize:vertical;"></textarea>
    </div>
    <div class="field">
      <label>Industry Experience <span style="color:#C45D2C">*</span></label>
      <input type="text" id="experience" required placeholder="e.g. 2.5 years, 5+ years" />
    </div>
    <div class="field">
      <label>Current Company <span style="color:#C45D2C">*</span></label>
      <input type="text" id="company" required placeholder="e.g. Synopsys, Intel" />
    </div>

    <div class="field">
      <label>Coupon code (optional)</label>
      <div style="display:flex; gap:0.5rem;">
        <input type="text" id="coupon" placeholder="Enter code" style="flex:1;" />
        <button type="button" id="apply-coupon" class="btn" style="width:auto; padding:0.7rem 1.2rem; font-size:0.82rem;">Apply</button>
      </div>
      <div id="coupon-msg" style="font-size:0.78rem; margin-top:0.3rem;"></div>
    </div>

    <button type="button" id="pay-btn" class="btn"></button>
  </div>

  <footer>
    <a href="https://akarshanarora.com">akarshanarora.com</a> &nbsp;&middot;&nbsp; <a href="/">Courses</a> &nbsp;&middot;&nbsp; <a href="/resources/">Guides</a>
  </footer>

  <span id="sched" hidden data-schedule={JSON.stringify(schedule)} data-dur={availability.slotDuration} data-buffer={availability.bufferMinutes}></span>
</BaseLayout>

<style>
  .container { max-width: 480px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .eyebrow { font-family: 'JetBrains Mono',monospace; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.2em; color:var(--accent); margin-bottom:0.5rem; }
  h1 { font-size:2rem; font-weight:800; letter-spacing:-0.03em; margin-bottom:0.2rem; }
  #service-meta { color:var(--muted); margin-bottom:2rem; }
  .err { display:none; color:#9A3324; font-size:0.78rem; margin-bottom:0.5rem; margin-top:0.35rem; }

  /* Date pills */
  .date-pills {
    display: flex; gap: 0.5rem; overflow-x: auto;
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .date-pills::-webkit-scrollbar { display: none; }
  .date-pill {
    flex: 0 0 auto;
    display: flex; flex-direction: column; align-items: center;
    padding: 0.55rem 0.9rem;
    border: 1.5px solid var(--hairline);
    border-radius: 12px;
    background: var(--surface);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
    min-width: 68px;
  }
  .date-pill:hover { border-color: var(--accent); background: #fdf8f5; }
  .date-pill.sel { background: var(--accent); border-color: var(--accent); color: #fff; }
  .date-pill.full { opacity: 0.4; pointer-events: none; text-decoration: line-through; }
  .date-pill-dow { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: inherit; opacity: 0.7; }
  .date-pill.sel .date-pill-dow { opacity: 0.85; }
  .date-pill-num { font-size: 0.92rem; font-weight: 700; color: inherit; margin-top: 1px; }

  /* Time slots — :global() so JS-created elements get styled */
  #time-slots { display: flex; flex-wrap: wrap; gap: 0.45rem; min-height: 2.5rem; align-items: center; }
  :global(.slot) {
    display: inline-block;
    padding: 0.55rem 1.1rem;
    border: 1.5px solid var(--hairline);
    border-radius: 10px;
    font-size: 0.88rem;
    cursor: pointer;
    background: var(--surface);
    font-family: 'JetBrains Mono',monospace;
    font-weight: 500;
    transition: all 0.12s;
  }
  :global(.slot:hover) { border-color: var(--accent); background: #fdf8f5; }
  :global(.slot.sel) { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 700; }
  :global(.no-slots) { color: var(--muted); font-size: 0.85rem; font-style: italic; }

  /* Form fields */
  .field { margin-bottom: 1rem; }
  .field label { display:block; font-family:'JetBrains Mono',monospace; font-size:0.68rem; font-weight:500; color:#A3A39E; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.4rem; }
  .field input { width:100%; padding:0.7rem 0.85rem; background:var(--surface); border:1px solid var(--hairline); border-radius:8px; color:var(--ink); font-size:0.9rem; font-family:inherit; }
  .field input:focus { outline:none; border-color:var(--accent); }
  .btn { width:100%; padding:0.8rem; margin-top:0.5rem; background:var(--accent); color:#fff; border:none; border-radius:8px; font-size:0.92rem; font-weight:600; font-family:inherit; cursor:pointer; transition: background 0.2s; white-space:normal; }
  .btn:hover { background:#a84c1f; }
  .btn:disabled { opacity:0.5; pointer-events:none; }
</style>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
(function(){
  const sched = JSON.parse(document.getElementById('sched').dataset.schedule);
  const defaultDur = parseInt(document.getElementById('sched').dataset.dur);
  const buffer = parseInt(document.getElementById('sched').dataset.buffer) || 5;
  let selDate = null, selTime = null;

  // URL params
  const p = new URLSearchParams(location.search);
  const service = p.get('s'), name = p.get('n');
  const dur = parseInt(p.get('d')) || defaultDur;
  const interval = dur + buffer;
  if(!service||!name) return location.href='/book/';

  let originalPrice = 0;
  let discountedPrice = 0;
  let appliedCoupon = null;
  let priceLoaded = false;

  // Fetch real price from server — URL param is fallback only
  async function loadServicePrice() {
    try {
      const r = await fetch('/api/service?slug=' + encodeURIComponent(service));
      if (r.ok) {
        const svc = await r.json();
        originalPrice = svc.price;
        discountedPrice = svc.price;
        priceLoaded = true;
        updatePriceDisplay();
      }
    } catch (_) {}
    // Fallback to URL param
    if (!priceLoaded) {
      originalPrice = parseInt(p.get('p')||'0');
      discountedPrice = originalPrice;
      if (originalPrice) { priceLoaded = true; updatePriceDisplay(); }
    }
  }

  function updatePriceDisplay() {
    document.getElementById('service-title').textContent = name;
    document.getElementById('service-meta').textContent = dur + ' min';
    const btn = document.getElementById('pay-btn');
    if (!priceLoaded) {
      btn.textContent = 'Loading...';
    } else if (discountedPrice < originalPrice) {
      btn.innerHTML = '₹' + discountedPrice + ' <s style="opacity:0.6; font-weight:400;">₹' + originalPrice + '</s>';
    } else {
      btn.textContent = '₹' + discountedPrice;
    }
  }
  loadServicePrice().then(updatePriceDisplay);

  // Coupon
  let couponValidating = false;
  const couponInput = document.getElementById('coupon');
  const applyBtn = document.getElementById('apply-coupon');
  const couponMsg = document.getElementById('coupon-msg');

  function removeCoupon() {
    discountedPrice = originalPrice;
    appliedCoupon = null;
    couponInput.value = '';
    couponInput.disabled = false;
    couponMsg.textContent = '';
    applyBtn.textContent = 'Apply';
    applyBtn.style.background = '';
    applyBtn.onclick = applyCoupon;
    updatePriceDisplay();
  }

  async function applyCoupon() {
    const code = couponInput.value.trim();
    if (!code) { couponMsg.textContent = ''; return; }
    if (couponValidating) return;
    couponValidating = true;
    couponMsg.style.color = 'var(--muted)';
    couponMsg.textContent = 'Checking...';
    try {
      const r = await fetch('/api/validate-coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, service, price: originalPrice })
      });
      const data = await r.json();
      if (data.valid) {
        discountedPrice = data.discountedPrice;
        appliedCoupon = code;
        couponMsg.style.color = '#3A5A40';
        couponMsg.textContent = data.discountPercent + '% off';
        couponInput.disabled = true;
        applyBtn.textContent = 'Remove';
        applyBtn.style.background = '#9A3324';
        applyBtn.onclick = removeCoupon;
        updatePriceDisplay();
      } else {
        discountedPrice = originalPrice;
        appliedCoupon = null;
        couponMsg.style.color = '#9A3324';
        couponMsg.textContent = data.error || 'Invalid coupon';
        updatePriceDisplay();
      }
    } catch (_) {
      couponMsg.style.color = '#9A3324';
      couponMsg.textContent = 'Failed to check coupon.';
    }
    couponValidating = false;
  }

  applyBtn.onclick = applyCoupon;
  couponInput.onkeydown = (e) => {
    if (e.key === 'Enter') { e.preventDefault(); applyBtn.click(); }
  };

  function scrollToSelected() {
    const sel = document.querySelector('.date-pill.sel');
    if (sel) sel.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  function timeLabel(mins) {
    const h = Math.floor(mins / 60), m = mins % 60;
    const ampm = h >= 12 ? 'PM' : 'AM';
    const h12 = h > 12 ? h - 12 : h === 0 ? 12 : h;
    return h12 + ':' + String(m).padStart(2, '0') + ' ' + ampm;
  }

  async function loadSlots(date, dow) {
    const c = document.getElementById('time-slots');
    selTime = null;
    document.getElementById('time-error').style.display = 'none';
    c.innerHTML = '<span class="no-slots">Loading slots...</span>';

    // Fetch booked slots first
    let booked = [];
    try {
      const r = await fetch('/api/booked-slots?date=' + encodeURIComponent(date));
      if (r.ok) { const d = await r.json(); booked = d.slots || []; }
    } catch (_) {}

    // Render only available slots
    const ranges = sched[dow] || [];
    let hasSlot = false;
    c.innerHTML = '';

    ranges.forEach(([s, e]) => {
      const [sh, sm] = s.split(':').map(Number), [eh, em] = e.split(':').map(Number);
      let cur = sh * 60 + sm, end = eh * 60 + em;
      while (cur + dur <= end) {
        const txt = timeLabel(cur);
        if (!booked.includes(txt)) {
          const el = document.createElement('span');
          el.className = 'slot';
          el.textContent = txt;
          el.dataset.time = txt;
          el.onclick = () => {
            c.querySelectorAll('.slot').forEach(x => x.classList.remove('sel'));
            el.classList.add('sel');
            selTime = txt;
            document.getElementById('time-error').style.display = 'none';
          };
          c.appendChild(el);
          hasSlot = true;
        }
        cur += interval;
      }
    });

    if (!hasSlot) {
      c.innerHTML = '<span class="no-slots">All slots booked for this date. Pick another date.</span>';
    }
  }

  // Pre-fetch availability for all dates — disable fully-booked ones
  (async () => {
    const pills = document.querySelectorAll('.date-pill');
    const bookedByDate = {};
    await Promise.all([...pills].map(async (btn) => {
      try {
        const r = await fetch('/api/booked-slots?date=' + encodeURIComponent(btn.dataset.date));
        if (r.ok) { const d = await r.json(); bookedByDate[btn.dataset.date] = d.slots || []; }
      } catch (_) { bookedByDate[btn.dataset.date] = []; }
    }));
    pills.forEach(btn => {
      const dow = parseInt(btn.dataset.dow);
      const ranges = sched[dow] || [];
      let totalSlots = 0;
      ranges.forEach(([s, e]) => {
        const [sh, sm] = s.split(':').map(Number), [eh, em] = e.split(':').map(Number);
        let cur = sh * 60 + sm, end = eh * 60 + em;
        while (cur + dur <= end) { totalSlots++; cur += interval; }
      });
      const booked = bookedByDate[btn.dataset.date] || [];
      if (booked.length >= totalSlots) btn.classList.add('full');
    });
  })();

  // Date pill clicks
  document.querySelectorAll('.date-pill').forEach(btn => {
    btn.onclick = () => {
      if (btn.classList.contains('full')) return;
      document.querySelectorAll('.date-pill').forEach(d => d.classList.remove('sel'));
      btn.classList.add('sel');
      selDate = btn.dataset.date;
      document.getElementById('date-error').style.display = 'none';
      loadSlots(selDate, parseInt(btn.dataset.dow));
      scrollToSelected();
    };
  });

  // Pay
  document.getElementById('pay-btn').onclick = async () => {
    const n = document.getElementById('name').value.trim();
    const e = document.getElementById('email').value.trim();
    const ph = document.getElementById('phone').value.trim();
    const about = document.getElementById('about').value.trim();
    const experience = document.getElementById('experience').value.trim();
    const company = document.getElementById('company').value.trim();
    const answers = JSON.stringify({ about, experience, company });
    let ok = true;
    if(!selDate){ document.getElementById('date-error').style.display = 'block'; ok = false; }
    if(!selTime){ document.getElementById('time-error').style.display = 'block'; ok = false; }
    if(!n || !e || !e.includes('@')){ alert('Enter name and valid email.'); ok = false; }
    if(!about){ alert('Tell us what the call is about.'); ok = false; }
    if(!experience){ alert('Enter your industry experience.'); ok = false; }
    if(!company){ alert('Enter your current company.'); ok = false; }
    if(!ok) return;
    const btn = document.getElementById('pay-btn');
    btn.textContent = 'Processing...'; btn.disabled = true;
    try {
      const r = await fetch('/api/create-order', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ service, serviceName: name, price: discountedPrice, originalPrice, date: selDate, time: selTime, name: n, email: e, phone: ph, answersJson: answers, couponCode: appliedCoupon }) });
      const data = await r.json();
      if (data.error) throw new Error(data.error);
      if (data.free) {
        location.href = '/book/confirmed/?orderId=' + data.orderId;
        return;
      }
      new Razorpay({ key: 'rzp_test_SkCAElXSARTppL', amount: discountedPrice * 100, currency: 'INR', name, description: selDate + ' at ' + selTime, order_id: data.orderId, handler: (response) => { location.href = '/book/confirmed/?orderId=' + data.orderId + '&paymentId=' + response.razorpay_payment_id + '&signature=' + response.razorpay_signature; }, prefill: { name: n, email: e, contact: ph }, theme: { color: '#C45D2C' } }).open();
    } catch (_) { alert('Something went wrong. Try again.'); }
    updatePriceDisplay(); btn.disabled = false;
  };
})();
</script>
