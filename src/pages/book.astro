---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Book a Session">
  <nav>
    <a href="https://akarshanarora.com" class="nav-brand">Akarshan Arora</a>
    <div class="nav-links">
      <a href="https://akarshanarora.com">Who am I</a>
      <a href="https://www.linkedin.com/in/aroraakarshan/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://topmate.io/akarshanarora" target="_blank" rel="noopener" class="nav-cta">Book a 1:1</a>
    </div>
  </nav>

  <div style="max-width:1000px;margin:0 auto;padding:2rem 2rem 0;">
    <a href="/" class="back-link">&larr; Courses</a>
  </div>

  <section class="hero">
    <div class="hero-eyebrow">1-on-1 Sessions</div>
    <h1>Pick a topic.</h1>
  </section>

  <div class="grid" id="services-grid">
    <div style="text-align:center;grid-column:1/-1;color:var(--muted);padding:2rem;">Loading...</div>
  </div>

  <footer>
    <a href="https://akarshanarora.com">akarshanarora.com</a> &nbsp;&middot;&nbsp; <a href="/">Courses</a> &nbsp;&middot;&nbsp; <a href="/resources/">Guides</a>
  </footer>
</BaseLayout>

<script>
(async () => {
  const grid = document.getElementById('services-grid');
  try {
    const r = await fetch('/api/services');
    const svcs = await r.json();
    if (!svcs.length) {
      grid.innerHTML = '<div style="text-align:center;grid-column:1/-1;color:var(--muted);padding:2rem;">No sessions available right now.</div>';
      return;
    }
    const fmt = (p) => '₹' + p.toLocaleString('en-IN');
    grid.innerHTML = svcs.map(s => `
      <a href="/book/schedule/?s=${s.slug}&n=${encodeURIComponent(s.name)}&d=55" class="card">
        <div class="card-body">
          <div class="card-tag">55 min &middot; ${fmt(s.price)}</div>
          <h2>${s.name}</h2>
          <p>1-on-1 session. Get personalised guidance from an industry professional.</p>
        </div>
        <div class="card-footer"><span>Select &rarr;</span></div>
      </a>
    `).join('');
  } catch (_) {
    grid.innerHTML = '<div style="text-align:center;grid-column:1/-1;color:var(--muted);padding:2rem;">Could not load sessions. Try again.</div>';
  }
})();
</script>
