---
import resources from '../../data/resources.json';
import BaseLayout from '../../layouts/BaseLayout.astro';

const titles = Object.fromEntries(resources.map(r => [r.file, r.title]));
---

<BaseLayout title="Download">
  <nav>
    <a href="https://akarshanarora.com" class="nav-brand">Akarshan Arora</a>
    <div class="nav-links">
      <a href="https://akarshanarora.com">Who am I</a>
      <a href="https://www.linkedin.com/in/aroraakarshan/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://topmate.io/akarshanarora" target="_blank" rel="noopener" class="nav-cta">Book a 1:1</a>
    </div>
  </nav>

  <style>
    .container {
      max-width: 440px; width: 100%; margin: 0 auto;
      padding: 4rem 1rem;
    }
    h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.04em; margin-bottom: 0.35rem; }
    .subtitle { color: #777; font-size: 0.92rem; margin-bottom: 2rem; }
    .field { margin-bottom: 1rem; }
    .field label { display: block; font-size: 0.8rem; font-weight: 600; color: #555; margin-bottom: 0.3rem; }
    .field input {
      width: 100%; padding: 0.75rem 0.9rem;
      background: #fafafa; border: 1px solid #e5e5e5; border-radius: 8px;
      color: #1A1A1A; font-size: 0.92rem; font-family: inherit;
      transition: border-color 0.2s;
    }
    .field input:focus { outline: none; border-color: #C45D2C; background: #fff; }
    .field input::placeholder { color: #bbb; }
    .error { color: #9A3324; font-size: 0.75rem; margin-top: 0.2rem; display: none; }
    .btn {
      width: 100%; padding: 0.8rem; margin-top: 0.5rem;
      background: #C45D2C; color: #fff; border: none; border-radius: 8px;
      font-size: 0.92rem; font-weight: 600; font-family: inherit; cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover { background: #a84c1f; }
    .btn.done { background: #3A5A40; pointer-events: none; }
    .dl-link { display: none; text-align: center; margin-top: 1rem; font-size: 0.88rem; }
    .dl-link a { color: #C45D2C; text-decoration: none; font-weight: 600; }
    .dl-link a:hover { text-decoration: underline; }
  </style>

  <div class="container">
    <a href="/resources/" class="back-link">&larr; Guides</a>
    <h1 id="resource-title">Download</h1>
    <p class="subtitle">Enter your details to get the PDF.</p>
    <form id="download-form">
      <div class="field">
        <label>Name</label>
        <input type="text" name="name" required placeholder="Your full name" />
        <div class="error">Please enter your name.</div>
      </div>
      <div class="field">
        <label>Email</label>
        <input type="email" name="email" required placeholder="you@example.com" />
        <div class="error">Please enter a valid email address.</div>
      </div>
      <div class="field">
        <label>Phone &mdash; optional</label>
        <input type="tel" name="phone" placeholder="+91 99999 99999" />
      </div>
      <button type="submit" class="btn">Download PDF</button>
    </form>
  </div>

  <span id="titles-data" hidden data-titles={JSON.stringify(titles)}></span>
  <script>
    const titles = JSON.parse(document.getElementById('titles-data').dataset.titles);
    const params = new URLSearchParams(window.location.search);
    const resource = params.get('r') || '';
    document.getElementById('resource-title').textContent = titles[resource] || 'Download';

    document.getElementById('download-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const name = form.querySelector('[name="name"]').value.trim();
      const email = form.querySelector('[name="email"]').value.trim();
      const phone = form.querySelector('[name="phone"]').value.trim();
      const btn = form.querySelector('.btn');
      const dl = form.querySelector('.dl-link');

      form.querySelectorAll('.error').forEach(el => el.style.display = 'none');

      let valid = true;
      if (!name) { form.querySelector('[name="name"]').parentElement.querySelector('.error').style.display = 'block'; valid = false; }
      if (!email || !email.includes('@')) { form.querySelector('[name="email"]').parentElement.querySelector('.error').style.display = 'block'; valid = false; }
      if (!valid) return;

      btn.textContent = 'Downloading...';
      btn.style.opacity = '0.7';

      try {
        const res = await fetch('/api/download', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, resource }),
        });

        if (res.ok) {
          const blob = await res.blob();
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = resource;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
          URL.revokeObjectURL(link.href);
          window.location.href = '/resources/thank-you/';
        } else {
          btn.textContent = 'Download failed';
          btn.style.opacity = '1';
        }
      } catch (_) {
        btn.textContent = 'Download failed';
        btn.style.opacity = '1';
      }
    });
  </script>
</BaseLayout>
