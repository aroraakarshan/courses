---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Akarshan Arora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #1A1A1A;
      --paper: #FAFAF7;
      --accent: #C45D2C;
      --hairline: #E5E5E0;
      --muted: #6B6B66;
      --tertiary: #A3A39E;
      --surface: #fff;
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--paper);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* Nav */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem; border-bottom: 1px solid var(--hairline);
      position: sticky; top: 0;
      background: rgba(250,250,247,0.94); backdrop-filter: blur(12px); z-index: 10;
    }
    .nav-brand { font-weight: 700; font-size: 0.95rem; color: var(--ink); text-decoration: none; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.86rem; transition: color 0.2s; }
    .nav-links a:hover { color: var(--ink); }
    .nav-cta {
      padding: 0.45rem 1rem;
      background: var(--accent); color: #fff; border-radius: 7px;
      font-weight: 600; font-size: 0.8rem; transition: background 0.2s;
    }
    .nav-cta:hover { background: #a84c1f; }

    /* Shared card styles */
    .card {
      display: flex; flex-direction: column;
      background: var(--surface); border: 1px solid var(--hairline);
      border-radius: 12px; overflow: hidden;
      transition: border-color 0.25s, box-shadow 0.25s;
      text-decoration: none; color: inherit;
    }
    .card:hover { border-color: var(--accent); box-shadow: 6px 6px 0 0 var(--accent); }
    .card-body { padding: 1.75rem 1.75rem 0; flex: 1; }
    .card-body h2 { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.35rem; }
    .card-body p { color: var(--muted); font-size: 0.88rem; line-height: 1.55; }
    .card-footer {
      padding: 1.25rem 1.75rem 1.75rem;
      font-size: 0.85rem; font-weight: 600; color: var(--accent);
    }
    .card-footer span { display: inline-flex; align-items: center; gap: 0.4rem; transition: gap 0.25s; }
    .card:hover .card-footer span { gap: 0.8rem; }
    .card-tag {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.14em;
      color: var(--accent); margin-bottom: 0.65rem;
    }

    /* Hero */
    .hero { padding: 5rem 2rem 3rem; text-align: center; max-width: 660px; margin: 0 auto; }
    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em;
      color: var(--accent); margin-bottom: 1rem;
    }
    .hero h1 { font-size: clamp(2.4rem, 5vw, 3.2rem); font-weight: 800; letter-spacing: -0.04em; line-height: 1.12; margin-bottom: 1rem; }
    .hero p { color: var(--muted); font-size: 1.05rem; max-width: 440px; margin: 0 auto; }

    /* Grid */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 1.5rem; padding: 0 2rem 4rem; max-width: 1000px; margin: 0 auto; }

    /* Support */
    .support { text-align: center; padding: 4rem 2rem; border-top: 1px solid var(--hairline); }
    .support h3 { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
    .support p { color: var(--muted); margin-bottom: 1.25rem; }

    /* Footer */
    footer { text-align: center; padding: 2rem; border-top: 1px solid var(--hairline); color: var(--tertiary); font-size: 0.84rem; }
    footer a { color: var(--muted); }

    @media (max-width: 480px) {
      .grid { grid-template-columns: 1fr; padding: 0 1rem 3rem; }
      .hero { padding: 3rem 1.25rem 2rem; }
      nav { padding: 1rem 1.25rem; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
