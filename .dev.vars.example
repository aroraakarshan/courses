# Razorpay — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Google Calendar — optional, for auto Meet links
# Create service account at https://console.cloud.google.com/apis/credentials
# Enable Calendar API, download JSON key, paste the entire content here
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----...","client_email":"..."}
